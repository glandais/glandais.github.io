#!/bin/bash
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Pre-push: building DOCX, PDF and site..."
uv run python -m scripts.build all --lang fr

echo "Pre-push: copying downloads to docs/..."
mkdir -p docs/downloads
cp dist/pdf/*.pdf docs/downloads/
cp dist/docx/*.docx docs/downloads/

# Stage and amend the push commit with updated docs
git add docs/
if ! git diff --cached --quiet; then
    echo "Pre-push: committing updated docs/downloads..."
    git commit --no-verify -m "docs: update generated files"
fi

echo "Pre-push: done."
