#!/bin/bash
set -e

export PATH="$HOME/.local/bin:$HOME/.pyenv/bin:$HOME/.pyenv/shims:$PATH"

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Clean previous build
rm -rf dist/docx dist/pdf

echo "Pre-commit: building DOCX..."
uv run python -m scripts.build docx --lang fr
echo "Pre-commit: building PDF..."
uv run python -m scripts.build pdf --lang fr
echo "Pre-commit: building site..."
uv run python -m scripts.build site --lang fr

echo "Pre-commit: copying downloads to docs/..."
mkdir -p docs/downloads
cp dist/pdf/*.pdf docs/downloads/
cp dist/docx/*.docx docs/downloads/

git add docs/

echo "Pre-commit: done."
